{
  "name": "@tentaclepay/tpay",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:darwin-arm64": "bun run scripts/build.ts --target bun-darwin-arm64 --outfile dist/tpay-darwin-arm64",
    "build:darwin-x64": "bun run scripts/build.ts --target bun-darwin-x64 --outfile dist/tpay-darwin-x64",
    "build:linux-x64": "bun run scripts/build.ts --target bun-linux-x64 --outfile dist/tpay-linux-x64",
    "build:linux-arm64": "bun run scripts/build.ts --target bun-linux-arm64 --outfile dist/tpay-linux-arm64",
    "lint": "biome check ./src",
    "lint-staged": "biome check ./src --write --staged --files-ignore-unknown=true --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "24"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@biomejs/biome": "2.4.15",
    "@mysten/sui": "^2.17.0",
    "@tentaclepay/sui-x402": "^2.1.12",
    "@x402/core": "^2.15.0",
    "chalk": "^5.6.2",
    "citty": "^0.2.2",
    "parse-headers": "^2.0.6"
  },
  "optionalDependencies": {
    "node-mac-auth": "^1.1.0"
  },
  "trustedDependencies": [
    "node-mac-auth"
  ]
}
